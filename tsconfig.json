{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "contracts/**/*.ts",
    "shared/**/*.ts",
    "adapters/**/*.ts",
    "stages/**/*.ts",
    "pipeline/**/*.ts",
    "cmd/**/*.ts",
    "tests/ts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist-lib"
  ]
}
